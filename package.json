        "@langchain/core": "^1.2.1",
        "@langchain/langgraph": "^1.4.7",
        "connect-mongo": "^6.0.0",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-session": "^1.19.0",
        "langchain": "^1.5.2",
        "mongoose": "^9.7.4",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-session": "^1.19.0",
        "@types/passport": "^1.0.17",
        "@types/passport-google-oauth20": "^2.0.1",
        "nodemon": "^3.1.14",
        "ts-node": "^10.9.2",
